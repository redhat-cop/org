{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions",
    ":enablePreCommit",
    "schedule:earlyMondays"
  ],
  "timezone": "Etc/UTC",
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "gcr.io/k8s-prow/ghproxy",
        "gcr.io/k8s-prow/peribolos"
      ],
      "matchUpdateTypes": [
        "pinDigest"
      ],
      "enabled": false
    }
  ]
}
